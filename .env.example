# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — titles, trends, news, decisions (no media generation)
OPENAI_API_KEY=

# AWS S3 storage (default provider)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
# Optional: custom CDN URL for public assets
AWS_S3_PUBLIC_URL=

# Storage provider: s3 | supabase
STORAGE_PROVIDER=s3
SUPABASE_STORAGE_BUCKET=uploads

# API routing — leave empty when frontend and API share same origin (Vercel monolith)
# Set to AWS ECS URL when splitting frontend (Vercel) and backend (AWS)
NEXT_PUBLIC_API_BASE_URL=
API_BASE_URL=

# Admin access (comma-separated Supabase user UUIDs)
ADMIN_USER_IDS=

# Cron secret for scheduled jobs (Vercel Cron / external scheduler)
CRON_SECRET=

# Node environment
NODE_ENV=production
